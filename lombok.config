# lombok.config
# This file marks the Lombok configuration root for this project.
# Required on Windows with Java 21 so Lombok can find annotated sources.

# Use @FieldDefaults(level=AccessLevel.PRIVATE) project-wide (optional but good practice)
lombok.fieldDefaults.defaultLevel = PRIVATE

# Suppress warning about @Builder on entities with defaults
lombok.builder.flagUsage = warning

# Ensure log field is named 'log' for @Slf4j (default, made explicit)
lombok.log.fieldName = log

# Copy annotations to the generated @Builder constructor parameters
lombok.copyableAnnotations += jakarta.validation.constraints.NotNull
lombok.copyableAnnotations += jakarta.validation.constraints.NotBlank
