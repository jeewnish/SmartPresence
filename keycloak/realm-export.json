{
  "realm": "smartpresence",
  "enabled": true,
  "displayName": "SmartPresence",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "accessTokenLifespan": 3600,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      { "name": "SMARTPRESENCE_ADMIN",    "description": "SmartPresence Administrator" },
      { "name": "SMARTPRESENCE_LECTURER", "description": "SmartPresence Lecturer" },
      { "name": "SMARTPRESENCE_STUDENT",  "description": "SmartPresence Student" }
    ]
  },
  "clients": [
    {
      "clientId": "smartpresence-backend",
      "name": "SmartPresence Backend (Admin API)",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "smartpresence-admin-secret",
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "redirectUris": [
        "http://localhost:8080/*",
        "http://localhost:8080/api/v1/swagger-ui/oauth2-redirect.html"
      ],
      "webOrigins": ["http://localhost:8080"],
      "protocol": "openid-connect",
      "attributes": {
        "access.token.lifespan": "3600"
      }
    },
    {
      "clientId": "smartpresence-app",
      "name": "SmartPresence Mobile App",
      "enabled": true,
      "publicClient": true,
      "clientAuthenticatorType": "client-secret",
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "protocol": "openid-connect"
    }
  ],
  "users": [
