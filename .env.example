# ─── SmartPresence Frontend — environment variables ───────────────────────────
# Copy this file to .env.local and fill in your values.
# Vite only exposes variables prefixed with VITE_ to the browser.

# Backend Spring Boot base URL (without trailing slash).
# In development the Vite proxy rewrites /api → http://localhost:8080,
# so you can leave this commented out and the proxy will handle it.
# In production set this to your deployed API URL, e.g.:
# VITE_API_BASE_URL=https://api.youruni.edu/api/v1

# Keycloak settings — must match your realm-export.json
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=smartpresence
VITE_KEYCLOAK_CLIENT_ID=smartpresence-backend

# WebSocket URL for live check-in notifications (optional — fallback uses polling)
# VITE_WS_URL=ws://localhost:8080/api/v1/ws
