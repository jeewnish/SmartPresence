# ============================================================
#  SmartPresence — Environment Variables
#  Copy this to .env and fill in your values before running.
#  docker compose --env-file .env up -d
# ============================================================

# PostgreSQL password (used by both the DB container and the app)
DB_PASSWORD=Dev@Pass123

# Keycloak admin console password
KEYCLOAK_ADMIN_PASSWORD=admin

# Client secret — must match the value in keycloak/realm-export.json
# Default is already set to match the realm export.
KEYCLOAK_CLIENT_SECRET=smartpresence-admin-secret

# Static API key used by physical BLE beacons for /beacons/heartbeat
BEACON_API_KEY=sp-beacon-key-change-in-prod
